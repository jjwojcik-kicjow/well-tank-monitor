#include <WiFi.h>
#include <PubSubClient.h>
#include <ArduinoOTA.h>
#include <TelnetStream.h>

// --- Configuration ---
const char* ssid = "Hawkeyes";
const char* password = "springfield";
const char* mqtt_server = "10.0.4.227"; 

const char* mqtt_user = "mqtt-user";
const char* mqtt_password = "skeeter4IOT!"; 

const int trigPin = 5;
const int echoPin = 18;

// Updated Dimensions
const float tankHeight = 200.0;    // 2.0m (200cm)
const float sensorOffset = 15.0;   // 15cm offset

// --- Filter Configuration ---
const int burstReadings = 5;     // Number of rapid back-to-back samples per loop
const int numReadings = 5;       // Number of historical points for the moving average
int readings[numReadings];       
int readIndex = 0;               
int total = 0;                   
int averagePercentage = 0;       

WiFiClient espClient;
PubSubClient client(espClient);

void setup_wifi() {
  delay(10);
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) delay(500);
}

void reconnect() {
  while (!client.connected()) {
    TelnetStream.print("Attempting MQTT connection...");
    Serial.print("Attempting MQTT connection...");
    
    const char* willTopic = "home/tank/status";
    int willQoS = 1;
    bool willRetain = true;
    const char* willMessage = "offline";

    if (client.connect("ESP32_WaterSensor", mqtt_user, mqtt_password, willTopic, willQoS, willRetain, willMessage)) {
      TelnetStream.println("connected");
      Serial.println("connected");
      client.publish("home/tank/status", "online", true);
    } else {
      TelnetStream.print("failed, rc=");
      TelnetStream.print(client.state());
      TelnetStream.println(" try again in 5 seconds");
      
      Serial.print("failed, rc=");
      Serial.print(client.state());
      Serial.println(" try again in 5 seconds");
      delay(5000);
    }
  }
}

void setup_ota() {
  ArduinoOTA.setPort(3232);
  ArduinoOTA.setHostname("ESP32-WaterSensor");
  ArduinoOTA.begin();
}

void setup() {
  Serial.begin(115200);
  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);
  
  setup_wifi();
  setup_ota();
  TelnetStream.begin();
  
  client.setServer(mqtt_server, 1883);

  for (int thisReading = 0; thisReading < numReadings; thisReading++) {
    readings[thisReading] = 0;
  }
}

void loop() {
  ArduinoOTA.handle();

  if (!client.connected()) reconnect();
  client.loop();

  // 1. Take a rapid burst of samples to eliminate single-pulse errors
  long totalDuration = 0;
  int validSamplesCount = 0;

  for (int i = 0; i < burstReadings; i++) {
    digitalWrite(trigPin, LOW); delayMicroseconds(2);
    digitalWrite(trigPin, HIGH); delayMicroseconds(10);
    digitalWrite(trigPin, LOW);
    
    long duration = pulseIn(echoPin, HIGH, 30000); // 30ms timeout
    
    if (duration > 0) {
      totalDuration += duration;
      validSamplesCount++;
    }
    delay(30); // Short rest between burst pings to let echoes die down
  }

  // Evaluate if we got a reliable data point from the burst
  if (validSamplesCount > 0) {
    long avgDuration = totalDuration / validSamplesCount;
    
    float distance = avgDuration * 0.034 / 2; 
    float waterLevel = tankHeight - (distance - sensorOffset);
    int currentPercentage = constrain((waterLevel / tankHeight) * 100, 0, 100);

    // 2. Apply Moving Average Filter across historical data points
    total = total - readings[readIndex];         
    readings[readIndex] = currentPercentage;     
    total = total + readings[readIndex];         
    readIndex = readIndex + 1;                   

    if (readIndex >= numReadings) {
      readIndex = 0;                             
    }

    averagePercentage = total / numReadings;     

    // 3. Publish Data to MQTT
    char msgPercent[10];
    char msgDistance[10];
    
    sprintf(msgPercent, "%d", averagePercentage);
    dtostrf(distance, 5, 1, msgDistance); 

    client.publish("home/tank/level", msgPercent);
    client.publish("home/tank/distance", msgDistance); 

    // --- Logging ---
    String logMsg = "Distance: " + String(distance) + " cm | Raw Burst Avg: " + String(currentPercentage) + "% | Rolling Smoothed: " + String(msgPercent) + "%\n";
    Serial.print(logMsg);
    TelnetStream.print(logMsg);

  } else {
    Serial.println("Burst read completely failed, skipping loop.");
    TelnetStream.println("Burst read completely failed, skipping loop.");
  }

  // Non-blocking wait loop handling OTA background processes
  for (int i = 0; i < 100; i++) {
    ArduinoOTA.handle();
    delay(100); 
  }
}
