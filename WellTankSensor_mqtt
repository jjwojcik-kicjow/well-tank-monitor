#include <WiFi.h>
#include <PubSubClient.h>
#include <ArduinoOTA.h>
#include <TelnetStream.h> // Handles Serial over LAN

// --- Configuration ---
const char* ssid = "Hawkeyes";
const char* password = "springfield";
const char* mqtt_server = "10.0.4.227"; 

const char* mqtt_user = "mqtt-user";
const char* mqtt_password = "skeeter4IOT!"; 

const int trigPin = 5;
const int echoPin = 18;
const float tankHeight = 150.0; // 1.5m
const float sensorOffset = 5.0;

// --- Filter Configuration ---
const int numReadings = 5;       
int readings[numReadings];       
int readIndex = 0;               
int total = 0;                   
int averagePercentage = 0;       

WiFiClient espClient;
PubSubClient client(espClient);

void setup_wifi() {
  delay(10);
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) delay(500);
}

void reconnect() {
  while (!client.connected()) {
    TelnetStream.print("Attempting MQTT connection...");
    Serial.print("Attempting MQTT connection...");
    
    const char* willTopic = "home/tank/status";
    int willQoS = 1;
    bool willRetain = true;
    const char* willMessage = "offline";

    if (client.connect("ESP32_WaterSensor", mqtt_user, mqtt_password, willTopic, willQoS, willRetain, willMessage)) {
      TelnetStream.println("connected");
      Serial.println("connected");
      client.publish("home/tank/status", "online", true);
    } else {
      // Log to both local Serial and Network Telnet
      TelnetStream.print("failed, rc=");
      TelnetStream.print(client.state());
      TelnetStream.println(" try again in 5 seconds");
      
      Serial.print("failed, rc=");
      Serial.print(client.state());
      Serial.println(" try again in 5 seconds");
      delay(5000);
    }
  }
}

void setup_ota() {
  // Port defaults to 3232
  ArduinoOTA.setPort(3232);
  
  // Hostname appears in your Arduino IDE network ports list
  ArduinoOTA.setHostname("ESP32-WaterSensor");

  // Optional: Add a password to protect unauthorized flashes over your LAN
  // ArduinoOTA.setPassword("admin");

  ArduinoOTA.onStart([]() {
    String type = (ArduinoOTA.getCommand() == U_FLASH) ? "sketch" : "modification";
    TelnetStream.println("Start updating " + type);
  });
  ArduinoOTA.onEnd([]() {
    TelnetStream.println("\nEnd");
  });
  ArduinoOTA.onProgress([](unsigned int progress, unsigned int total) {
    TelnetStream.printf("Progress: %u%%\r", (progress / (total / 100)));
  });
  ArduinoOTA.onError([](ota_error_t error) {
    TelnetStream.printf("Error[%u]: ", error);
    if (error == OTA_AUTH_ERROR) TelnetStream.println("Auth Failed");
    else if (error == OTA_BEGIN_ERROR) TelnetStream.println("Begin Failed");
    else if (error == OTA_CONNECT_ERROR) TelnetStream.println("Connect Failed");
    else if (error == OTA_RECEIVE_ERROR) TelnetStream.println("Receive Failed");
    else if (error == OTA_END_ERROR) TelnetStream.println("End Failed");
  });

  ArduinoOTA.begin();
}

void setup() {
  Serial.begin(115200);
  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);
  
  setup_wifi();
  
  // Initialize OTA and Telnet logging after WiFi is stable
  setup_ota();
  TelnetStream.begin();
  
  client.setServer(mqtt_server, 1883);

  for (int thisReading = 0; thisReading < numReadings; thisReading++) {
    readings[thisReading] = 0;
  }
}

void loop() {
  // Crucial: Handle OTA requests frequently
  ArduinoOTA.handle();

  if (!client.connected()) reconnect();
  client.loop();

  // 1. Measure Distance
  digitalWrite(trigPin, LOW); delayMicroseconds(2);
  digitalWrite(trigPin, HIGH); delayMicroseconds(10);
  digitalWrite(trigPin, LOW);
  
  long duration = pulseIn(echoPin, HIGH);
  
  if (duration > 0) {
    float distance = duration * 0.034 / 2; 
    float waterLevel = tankHeight - (distance - sensorOffset);
    int currentPercentage = constrain((waterLevel / tankHeight) * 100, 0, 100);

    // 2. Apply Moving Average Filter
    total = total - readings[readIndex];         
    readings[readIndex] = currentPercentage;     
    total = total + readings[readIndex];         
    readIndex = readIndex + 1;                   

    if (readIndex >= numReadings) {
      readIndex = 0;                             
    }

    averagePercentage = total / numReadings;     

    // 3. Publish Data to MQTT
    char msgPercent[10];
    char msgDistance[10];
    
    sprintf(msgPercent, "%d", averagePercentage);
    dtostrf(distance, 5, 1, msgDistance); 

    client.publish("home/tank/level", msgPercent);
    client.publish("home/tank/distance", msgDistance); 

    // --- Dual Logging: Local Serial & Network Telnet ---
    String logMsg = "Distance: " + String(distance) + " cm | Raw: " + String(currentPercentage) + "% | Smoothed: " + String(msgPercent) + "%\n";
    Serial.print(logMsg);
    TelnetStream.print(logMsg);

  } else {
    Serial.println("Sensor read failed (timeout)");
    TelnetStream.println("Sensor read failed (timeout)");
  }

  // Non-blocking loop processing for OTA updates during the 10s wait
  for (int i = 0; i < 100; i++) {
    ArduinoOTA.handle();
    delay(100); 
  }
}
