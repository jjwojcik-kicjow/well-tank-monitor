#include <WiFi.h>
#include <PubSubClient.h>

// --- Configuration ---
const char* ssid = "Hawkeyes";
const char* password = "springfield";
const char* mqtt_server = "10.0.4.227"; 

const char* mqtt_user = "mqtt-user";
const char* mqtt_password = "skeeter4IOT!"; 

const int trigPin = 5;
const int echoPin = 18;
const float tankHeight = 150.0; // 1.5m
const float sensorOffset = 5.0;

// --- Filter Configuration ---
const int numReadings = 5;       // Number of readings to average (higher = smoother but slower to adapt)
int readings[numReadings];       // The readings from the analog input
int readIndex = 0;               // The index of the current reading
int total = 0;                   // The running total
int averagePercentage = 0;       // The moving average percentage

WiFiClient espClient;
PubSubClient client(espClient);

void setup_wifi() {
  delay(10);
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) delay(500);
}

void reconnect() {
  while (!client.connected()) {
    Serial.print("Attempting MQTT connection...");
    if (client.connect("ESP32_WaterSensor", mqtt_user, mqtt_password)) {
      Serial.println("connected");
      client.publish("home/tank/status", "online");
    } else {
      Serial.print("failed, rc=");
      Serial.print(client.state());
      Serial.println(" try again in 5 seconds");
      delay(5000);
    }
  }
}

void setup() {
  Serial.begin(115200);
  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);
  setup_wifi();
  client.setServer(mqtt_server, 1883);

  // Initialize all the readings to 0 or a sensible default
  for (int thisReading = 0; thisReading < numReadings; thisReading++) {
    readings[thisReading] = 0;
  }
}

void loop() {
  if (!client.connected()) reconnect();
  client.loop();

  // 1. Measure Distance
  digitalWrite(trigPin, LOW); delayMicroseconds(2);
  digitalWrite(trigPin, HIGH); delayMicroseconds(10);
  digitalWrite(trigPin, LOW);
  
  long duration = pulseIn(echoPin, HIGH);
  
  // Basic validation: skip math if pulseIn timed out (0) or is completely out of physical bounds
  if (duration > 0) {
    float distance = duration * 0.034 / 2;
    float waterLevel = tankHeight - (distance - sensorOffset);
    int currentPercentage = constrain((waterLevel / tankHeight) * 100, 0, 100);

    // 2. Apply Moving Average Filter
    total = total - readings[readIndex];         // Subtract the oldest reading
    readings[readIndex] = currentPercentage;     // Read from the sensor
    total = total + readings[readIndex];         // Add the reading to the total
    readIndex = readIndex + 1;                   // Advance to the next position

    if (readIndex >= numReadings) {
      readIndex = 0;                             // Wrap around to the beginning
    }

    averagePercentage = total / numReadings;     // Calculate the average

    // 3. Publish Smoothed Data to MQTT
    char msg[10];
    sprintf(msg, "%d", averagePercentage);
    client.publish("home/tank/level", msg);

    Serial.print("Raw: "); Serial.print(currentPercentage);
    Serial.print("% | Smoothed Published: "); Serial.concat(msg); Serial.println("%");
  } else {
    Serial.println("Sensor read failed (timeout), skipping this loop execution.");
  }

  delay(10000); // Send every 10 seconds
}
